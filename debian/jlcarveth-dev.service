[Unit]
Description=jlcarveth.dev Personal Portfolio Website
Documentation=https://github.com/JLCarveth/jlcarveth.dev
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=jlcarveth-dev
Group=jlcarveth-dev
WorkingDirectory=/usr/share/jlcarveth-dev

Environment=PROD=1
EnvironmentFile=/etc/jlcarveth-dev/environment

ExecStart=/usr/bin/jlcarveth-dev

Restart=always
RestartSec=10

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true

[Install]
WantedBy=multi-user.target
