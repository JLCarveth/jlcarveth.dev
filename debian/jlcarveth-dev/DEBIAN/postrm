#!/bin/bash
set -e

PKG=jlcarveth-dev
SVCUSER=jlcarveth-dev

case "$1" in
    purge)
        # Clean up ucf registrations
        ucf --purge /etc/nginx/sites-available/$PKG || true
        ucfr --purge $PKG /etc/nginx/sites-available/$PKG || true

        # Remove nginx configs
        rm -f /etc/nginx/sites-available/$PKG
        rm -f /etc/nginx/sites-enabled/$PKG

        # Remove config directory
        rm -rf /etc/$PKG

        # Remove data directory
        rm -rf /usr/share/$PKG

        # Remove system user
        if id "$SVCUSER" &>/dev/null; then
            deluser --system "$SVCUSER" || true
        fi
        ;;
    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        # Keep configuration on remove to allow reinstallation
        ;;
esac

# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	systemctl --system daemon-reload >/dev/null || true
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = "purge" ]; then
	if [ -x "/usr/bin/deb-systemd-helper" ]; then
		deb-systemd-helper purge 'jlcarveth-dev.service' >/dev/null || true
	fi
fi
# End automatically added section


exit 0
